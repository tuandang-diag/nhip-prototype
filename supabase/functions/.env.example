# Server-side secrets. Never prefix these with VITE_ and never commit real values.
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5.4-mini

# Supabase injects these automatically in deployed Edge Functions.
# Add them only when serving functions in an unusual local environment.
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...
